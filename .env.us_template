# AI Trading Empire - US Live Trading Configuration
# Copy this to .env and fill in your actual API keys

# ===========================================
# US-COMPLIANT CRYPTOCURRENCY EXCHANGES
# ===========================================

# Coinbase Pro/Advanced (Primary)
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_SECRET=your_coinbase_secret_here
COINBASE_PASSPHRASE=your_coinbase_passphrase_here

# Kraken (Backup)
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_SECRET=your_kraken_secret_here

# Gemini (Backup)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_SECRET=your_gemini_secret_here

# ===========================================
# US MARKET DATA PROVIDERS
# ===========================================

# Alpha Vantage (Free tier: 5 calls/min, 500/day)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Twelve Data (Free tier available)
TWELVE_DATA_API_KEY=your_twelve_data_key_here

# Polygon.io (Free tier available)
POLYGON_API_KEY=your_polygon_key_here

# Finnhub (Free tier available)
FINNHUB_API_KEY=your_finnhub_key_here

# IEX Cloud (Free tier available)
IEX_CLOUD_API_KEY=your_iex_key_here

# FRED Economic Data (Free)
FRED_API_KEY=your_fred_key_here

# ===========================================
# NEWS & SENTIMENT SOURCES
# ===========================================

# News API (Free tier: 1000 requests/month)
NEWS_API_KEY=your_news_api_key_here

# Twitter API v2 (Essential tier available)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_CONSUMER_KEY=your_twitter_consumer_key_here
TWITTER_CONSUMER_SECRET=your_twitter_consumer_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here

# Reddit API (Free)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=AITradingEmpire/1.0

# ===========================================
# LIVE TRADING SETTINGS
# ===========================================

# Environment (development/production)
ENVIRONMENT=development

# Primary exchange for live trading
PRIMARY_EXCHANGE=coinbase_pro

# Enable live trading (set to 'true' only when ready)
LIVE_TRADING_ENABLED=false

# Paper trading mode (recommended for testing)
PAPER_TRADING_MODE=true

# Maximum position size (as decimal)
MAX_POSITION_SIZE=0.05

# Maximum daily loss limit (in USD)
MAX_DAILY_LOSS=500

# Risk management level (conservative/moderate/aggressive)
RISK_LEVEL=conservative

# ===========================================
# DATABASE & STORAGE
# ===========================================

# Database URL (SQLite by default for development)
DATABASE_URL=sqlite:///data/live_trading.db

# Redis (Optional - for caching and session management)
REDIS_URL=redis://localhost:6379/0

# ===========================================
# LOGGING & MONITORING
# ===========================================

# Log level (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# Enable trade logging
TRADE_LOGGING=true

# Enable performance monitoring
PERFORMANCE_MONITORING=true

# ===========================================
# COMPLIANCE & SAFETY
# ===========================================

# Enable compliance checks
COMPLIANCE_CHECKS=true

# Maximum leverage (for margin trading)
MAX_LEVERAGE=1.0

# Cool-down period between trades (seconds)
TRADE_COOLDOWN=30

# ===========================================
# API RATE LIMITING
# ===========================================

# Coinbase rate limit (requests per second)
COINBASE_RATE_LIMIT=5

# Kraken rate limit
KRAKEN_RATE_LIMIT=1

# Alpha Vantage rate limit (calls per minute)
ALPHA_VANTAGE_RATE_LIMIT=5

# ===========================================
# NOTIFICATION SETTINGS
# ===========================================

# Email notifications (optional)
EMAIL_NOTIFICATIONS=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Discord webhook (optional)
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# ===========================================
# GETTING FREE API KEYS:
# ===========================================
#
# Coinbase Pro: https://pro.coinbase.com/profile/api
# Kraken: https://www.kraken.com/u/security/api
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
# News API: https://newsapi.org/register
# Twitter: https://developer.twitter.com/
# Reddit: https://www.reddit.com/prefs/apps
# FRED: https://research.stlouisfed.org/docs/api/api_key.html
#
